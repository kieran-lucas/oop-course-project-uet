#!/bin/sh
# Auto-format staged Java files before commit

if git diff --cached --name-only --diff-filter=ACM | grep -qE '\.java$'; then
  echo "Running spotlessApply on staged Java files..."

  # On Windows (Git Bash / MSYS2), ./gradlew is the Unix shell script which
  # requires cygpath and egrep that are not available in Git Bash.
  # Use gradlew.bat via cmd.exe instead.
  case "$(uname -s)" in
    MINGW*|MSYS*|CYGWIN*)
      GRADLE_CMD="cmd //c gradlew.bat"
      ;;
    *)
      if [ -x ./gradlew ]; then
        GRADLE_CMD="./gradlew"
      elif [ -f ./gradlew.bat ]; then
        GRADLE_CMD="cmd //c gradlew.bat"
      else
        echo "Gradle wrapper not found. Aborting commit."
        exit 1
      fi
      ;;
  esac

  $GRADLE_CMD spotlessApply --quiet || {
    echo "spotlessApply failed. Aborting commit."
    exit 1
  }

  git diff --cached --name-only --diff-filter=ACM | grep -E '\.java$' | xargs git add
fi
