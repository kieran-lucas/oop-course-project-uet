<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="login-root"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.auction.ui.controller.LoginController">

   <VBox alignment="CENTER" maxWidth="460.0" spacing="16.0" styleClass="login-card">
      <padding>
         <Insets bottom="40.0" left="44.0" right="44.0" top="40.0" />
      </padding>

      <Label styleClass="app-title" text="Online Auction" />
      <Label fx:id="roleHintLabel" styleClass="app-subtitle" text="Sign in" />

      <VBox spacing="6.0">
         <Label styleClass="field-label" text="USERNAME" />
         <TextField fx:id="usernameField" promptText="Enter your username"
                    styleClass="text-field" />
      </VBox>

      <VBox spacing="6.0">
         <Label styleClass="field-label" text="PASSWORD" />
         <PasswordField fx:id="passwordField" promptText="Enter your password"
                        styleClass="text-field, password-field"
                        onAction="#handleLogin" />
      </VBox>

      <Label fx:id="errorLabel" styleClass="error-label" text=""
             visible="false" managed="false" wrapText="true" />

      <Button fx:id="loginButton" styleClass="primary-button" text="Sign in"
              maxWidth="Infinity" onAction="#handleLogin" />

      <HBox alignment="CENTER" spacing="20.0">
         <Hyperlink text="Don't have an account? Register" onAction="#goToRegister"
                    styleClass="link" />
         <Hyperlink text="Forgot password?" onAction="#goToForgotPassword"
                    styleClass="link" />
      </HBox>

      <Hyperlink text="← Back" onAction="#goBack" styleClass="back-link" />
   </VBox>

</StackPane>
