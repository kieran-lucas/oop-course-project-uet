<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="login-root"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.auction.ui.controller.LoginController">

   <VBox alignment="CENTER" maxWidth="420.0" spacing="16.0" styleClass="login-card">
      <padding>
         <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
      </padding>

      <!-- Tiêu đề ứng dụng -->
      <Label styleClass="app-title" text="Online Auction" />
      <Label styleClass="app-subtitle" fx:id="roleHintLabel" text="Đăng nhập" />

      <!-- Trường tên đăng nhập -->
      <VBox spacing="4.0">
         <Label styleClass="field-label" text="Tên đăng nhập" />
         <TextField fx:id="usernameField" promptText="Nhập tên đăng nhập"
                    styleClass="text-field" />
      </VBox>

      <!-- Trường mật khẩu -->
      <VBox spacing="4.0">
         <Label styleClass="field-label" text="Mật khẩu" />
         <PasswordField fx:id="passwordField" promptText="Nhập mật khẩu"
                        styleClass="text-field"
                        onAction="#handleLogin" />
      </VBox>

      <!-- Thông báo lỗi (ẩn mặc định) -->
      <Label fx:id="errorLabel" styleClass="error-label" text=""
             visible="false" wrapText="true" />

      <!-- Nút đăng nhập -->
      <Button fx:id="loginButton" styleClass="primary-button" text="Đăng nhập"
              maxWidth="Infinity" onAction="#handleLogin" />

      <!-- Liên kết hành động phụ -->
      <HBox alignment="CENTER" spacing="16.0">
         <Hyperlink text="Chưa có tài khoản? Đăng ký" onAction="#goToRegister"
                    styleClass="link" />
         <Hyperlink text="Quên mật khẩu?" onAction="#goToForgotPassword"
                    styleClass="link" />
      </HBox>

      <!-- Nút quay lại màn hình chào -->
      <Hyperlink text="← Quay lại" onAction="#goBack" styleClass="back-link" />
   </VBox>

</StackPane>
