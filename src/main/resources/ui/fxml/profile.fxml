<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="main-layout"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.ui.controller.ProfileController">

   <!-- ===== TOP BAR ===== -->
   <top>
      <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="top-bar">
         <padding>
            <Insets bottom="0.0" left="20.0" right="20.0" top="0.0" />
         </padding>
         <Button text="Back" styleClass="back-button" onAction="#goBack">
            <graphic><Region styleClass="back-icon" /></graphic>
         </Button>
         <Label styleClass="app-logo" text="My Profile" />
         <Region HBox.hgrow="ALWAYS" />
      </HBox>
   </top>

   <!-- ===== CENTER ===== -->
   <center>
      <VBox alignment="TOP_CENTER" spacing="0.0">
         <padding>
            <Insets bottom="32.0" left="40.0" right="40.0" top="28.0" />
         </padding>

         <VBox maxWidth="480.0" spacing="0.0" styleClass="form-card">

            <!-- Account info -->
            <VBox spacing="12.0">
               <padding><Insets bottom="20.0" left="24.0" right="24.0" top="24.0" /></padding>

               <Label styleClass="section-title" text="Account information" />

               <HBox spacing="16.0" alignment="CENTER_LEFT">
                  <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                     <Label styleClass="field-label" text="USERNAME" />
                     <Label fx:id="usernameLabel" styleClass="detail-text" text="—" />
                  </VBox>
                  <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                     <Label styleClass="field-label" text="ROLE" />
                     <Label fx:id="roleLabel" styleClass="detail-text" text="—" />
                  </VBox>
               </HBox>

               <!-- Balance — shown for BIDDER and SELLER. Styled via .balance-pill class
                    so the inline hardcoded #EFF6FF background is removed. -->
               <VBox fx:id="balanceBox" spacing="4.0" visible="false" managed="false"
                     styleClass="balance-pill">
                  <Label styleClass="field-label" text="WALLET BALANCE" />
                  <Label fx:id="profileBalanceLabel" styleClass="price-text" text="—" />
               </VBox>
            </VBox>

            <Separator />

            <!-- Actions -->
            <VBox spacing="10.0">
               <padding><Insets bottom="20.0" left="24.0" right="24.0" top="20.0" /></padding>

               <Button text="Change password" styleClass="secondary-button"
                       maxWidth="Infinity" onAction="#goToChangePassword" />
               <Button fx:id="depositButton" text="Top up wallet" styleClass="secondary-button"
                       maxWidth="Infinity" onAction="#goToDeposit"
                       visible="false" managed="false" />
            </VBox>

            <Separator />

            <!-- Danger zone -->
            <VBox spacing="0.0">
               <padding><Insets bottom="20.0" left="24.0" right="24.0" top="16.0" /></padding>
               <Button text="Log out" styleClass="card-logout-button"
                       maxWidth="Infinity" onAction="#handleLogout" />
            </VBox>

         </VBox>
      </VBox>
   </center>

</BorderPane>
