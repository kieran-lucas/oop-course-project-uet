<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="welcome-root"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.auction.ui.controller.WelcomeController">

   <VBox alignment="CENTER" spacing="60.0">

      <!-- Logo + Tiêu đề -->
      <VBox alignment="CENTER" spacing="12.0">
         <ImageView fitHeight="76.0" fitWidth="76.0" pickOnBounds="true" preserveRatio="true">
            <image>
               <Image url="@../../icons/auction.png" />
            </image>
         </ImageView>
         <Label styleClass="welcome-title" text="Auction House" />
         <Label styleClass="welcome-subtitle" text="Hệ thống đấu giá trực tuyến" />
      </VBox>

      <!-- Chọn vai trò -->
      <Label styleClass="welcome-prompt" text="Chọn vai trò để tiếp tục" />

      <HBox alignment="CENTER" spacing="28.0">

         <!-- Admin -->
         <Button styleClass="role-card" onAction="#goToLoginAsAdmin" mnemonicParsing="false">
            <graphic>
               <VBox alignment="CENTER" spacing="16.0">
                  <StackPane styleClass="role-icon-circle role-icon-admin-circle">
                     <ImageView fitHeight="75.0" fitWidth="75.0" pickOnBounds="true" preserveRatio="true">
                        <image><Image url="@../../icons/settings.png" /></image>
                     </ImageView>
                  </StackPane>
                  <VBox alignment="CENTER" spacing="4.0">
                     <Label styleClass="role-label" text="Quản trị viên" />
                     <Label styleClass="role-desc" text="Quản lý hệ thống" />
                  </VBox>
               </VBox>
            </graphic>
         </Button>

         <!-- Bidder -->
         <Button styleClass="role-card" onAction="#goToLoginAsBidder" mnemonicParsing="false">
            <graphic>
               <VBox alignment="CENTER" spacing="16.0">
                  <StackPane styleClass="role-icon-circle role-icon-bidder-circle">
                     <ImageView fitHeight="75.0" fitWidth="75.0" pickOnBounds="true" preserveRatio="true">
                        <image><Image url="@../../icons/computer.png" /></image>
                     </ImageView>
                  </StackPane>
                  <VBox alignment="CENTER" spacing="4.0">
                     <Label styleClass="role-label" text="Người đặt giá" />
                     <Label styleClass="role-desc" text="Tham gia đấu giá" />
                  </VBox>
               </VBox>
            </graphic>
         </Button>

         <!-- Seller -->
         <Button styleClass="role-card" onAction="#goToLoginAsSeller" mnemonicParsing="false">
            <graphic>
               <VBox alignment="CENTER" spacing="16.0">
                  <StackPane styleClass="role-icon-circle role-icon-seller-circle">
                     <ImageView fitHeight="75.0" fitWidth="75.0" pickOnBounds="true" preserveRatio="true">
                        <image><Image url="@../../icons/businessman.png" /></image>
                     </ImageView>
                  </StackPane>
                  <VBox alignment="CENTER" spacing="4.0">
                     <Label styleClass="role-label" text="Người bán" />
                     <Label styleClass="role-desc" text="Đăng bán sản phẩm" />
                  </VBox>
               </VBox>
            </graphic>
         </Button>

      </HBox>
   </VBox>

</StackPane>
