<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="main-layout"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.ui.controller.AdminPanelController">

   <!-- ===== TOP BAR ===== -->
   <top>
      <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="top-bar">
         <padding>
            <Insets bottom="0.0" left="20.0" right="20.0" top="0.0" />
         </padding>
         <Label styleClass="app-logo" text="Admin Panel" />
         <Region HBox.hgrow="ALWAYS" />
         <Label fx:id="usernameLabel" styleClass="username-label" text=""
                onMouseClicked="#handleProfile">
            <graphic><Region styleClass="user-icon" /></graphic>
         </Label>
         <Button text="Đăng xuất" styleClass="logout-button" onAction="#handleLogout"
                 style="-fx-font-family: 'Lexend'; -fx-font-weight: bold; -fx-font-size: 14px;">
            <graphic><Region styleClass="logout-icon" /></graphic>
         </Button>
      </HBox>
   </top>

   <!-- ===== CENTER (scrollable) ===== -->
   <center>
      <ScrollPane fitToWidth="true" styleClass="page-scroll">
         <VBox spacing="16.0">
            <padding>
               <Insets bottom="24.0" left="24.0" right="24.0" top="20.0" />
            </padding>

            <!-- ===== Auction management ===== -->
            <HBox alignment="CENTER_LEFT" spacing="12.0">
               <Label styleClass="section-title" text="Quản lý phiên đấu giá" />
               <Region HBox.hgrow="ALWAYS" />
               <Button text="Làm mới" styleClass="secondary-button" onAction="#handleRefresh" />
            </HBox>

            <HBox spacing="10.0" alignment="CENTER_LEFT">
               <TextField fx:id="searchField" promptText="Tìm kiếm phiên..."
                          styleClass="search-field" prefWidth="260.0" />
               <Button text="Tìm" styleClass="secondary-button" onAction="#handleSearch" />
            </HBox>

            <TableView fx:id="auctionTable" prefHeight="240.0" styleClass="auction-table">
               <columns>
                  <TableColumn fx:id="idCol" text="ID" prefWidth="60.0" />
                  <TableColumn fx:id="itemCol" text="Sản phẩm" prefWidth="245.0" />
                  <TableColumn fx:id="statusCol" text="Trạng thái" prefWidth="130.0" />
                  <TableColumn fx:id="priceCol" text="Giá hiện tại" prefWidth="220.0" />
                  <TableColumn fx:id="actionCol" text="Hành động" prefWidth="270.0" minWidth="240.0" />
               </columns>
               <placeholder>
                  <Label text="Không có phiên nào." />
               </placeholder>
            </TableView>

            <Label fx:id="statusLabel" styleClass="status-label" text=""
                   visible="false" managed="false" />

            <Separator />

            <!-- ===== Deposit request management ===== -->
            <HBox alignment="CENTER_LEFT" spacing="12.0">
               <Label styleClass="section-title" text="Yêu cầu nạp tiền (chờ duyệt)" />
               <Region HBox.hgrow="ALWAYS" />
               <Button text="Làm mới" styleClass="secondary-button" onAction="#handleRefreshDeposits" />
            </HBox>

            <TableView fx:id="depositTable" prefHeight="200.0" styleClass="auction-table">
               <columns>
                  <TableColumn fx:id="depositIdCol" text="ID" prefWidth="60.0" />
                  <TableColumn fx:id="depositUserCol" text="Người dùng" prefWidth="160.0" />
                  <TableColumn fx:id="depositAmountCol" text="Số tiền" prefWidth="230.0" />
                  <TableColumn fx:id="depositTimeCol" text="Thời gian" prefWidth="180.0" />
                  <TableColumn fx:id="depositActionCol" text="Hành động" prefWidth="220.0" minWidth="190.0" />
               </columns>
               <placeholder>
                  <Label text="Không có yêu cầu nạp tiền nào đang chờ." />
               </placeholder>
            </TableView>

            <Separator />

            <!-- ===== Password reset request management ===== -->
            <HBox alignment="CENTER_LEFT" spacing="12.0">
               <Label styleClass="section-title" text="Yêu cầu đặt lại mật khẩu (chờ duyệt)" />
               <Region HBox.hgrow="ALWAYS" />
               <Button text="Làm mới" styleClass="secondary-button" onAction="#handleRefreshPasswordResets" />
            </HBox>

            <TableView fx:id="passwordResetTable" prefHeight="180.0" styleClass="auction-table">
               <columns>
                  <TableColumn fx:id="prIdCol" text="ID" prefWidth="60.0" />
                  <TableColumn fx:id="prUsernameCol" text="Tên đăng nhập" prefWidth="150.0" />
                  <TableColumn fx:id="prEmailCol" text="Email" prefWidth="300.0" />
                  <TableColumn fx:id="prTimeCol" text="Thời gian yêu cầu" prefWidth="180.0" />
                  <TableColumn fx:id="prActionCol" text="Hành động" prefWidth="220.0" minWidth="190.0" />
               </columns>
               <placeholder>
                  <Label text="Không có yêu cầu đặt lại mật khẩu nào đang chờ." />
               </placeholder>
            </TableView>

            <Label fx:id="passwordResetStatusLabel" styleClass="status-label" text=""
                   visible="false" managed="false" wrapText="true" />

            <Separator />

            <!-- ===== User management ===== -->
            <Label styleClass="section-title" text="Quản lý người dùng" />

            <TableView fx:id="userTable" prefHeight="240.0" styleClass="auction-table">
               <columns>
                  <TableColumn fx:id="userIdCol" text="ID" prefWidth="60.0" />
                  <TableColumn fx:id="usernameCol" text="Tên đăng nhập" prefWidth="150.0" />
                  <TableColumn fx:id="emailCol" text="Email" prefWidth="300.0" />
                  <TableColumn fx:id="roleCol" text="Vai trò" prefWidth="100.0" />
                  <TableColumn fx:id="balanceCol" text="Số dư" prefWidth="230.0" />
                  <TableColumn fx:id="userActionCol" text="Hành động" prefWidth="120.0" minWidth="100.0" />
               </columns>
               <placeholder>
                  <Label text="Không có người dùng nào." />
               </placeholder>
            </TableView>

         </VBox>
      </ScrollPane>
   </center>

</BorderPane>
