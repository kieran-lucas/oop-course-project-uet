<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="login-root"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.auction.ui.controller.ForgotPasswordController">

   <VBox alignment="CENTER" maxWidth="400.0" spacing="14.0" styleClass="login-card">
      <padding>
         <Insets bottom="36.0" left="36.0" right="36.0" top="36.0" />
      </padding>

      <Label styleClass="app-title" text="Quên mật khẩu" />
      <Label styleClass="app-subtitle"
             text="Nhập email đã đăng ký. Admin sẽ xét duyệt và reset mật khẩu về 123456." />

      <VBox spacing="4.0">
         <Label styleClass="field-label" text="Email" />
         <TextField fx:id="emailField" promptText="Nhập địa chỉ email đã đăng ký"
                    styleClass="text-field" />
      </VBox>

      <Label fx:id="statusLabel" styleClass="status-label" text=""
             visible="false" wrapText="true" />

      <Button fx:id="submitButton" text="Gửi yêu cầu" styleClass="primary-button"
              maxWidth="Infinity" onAction="#handleSubmit" />

      <Button text="Quay lại đăng nhập" styleClass="secondary-button"
              maxWidth="Infinity" onAction="#goBack" />
   </VBox>

</StackPane>
