<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="login-root"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.auction.ui.controller.ForgotPasswordController">

   <VBox alignment="CENTER" maxWidth="400.0" spacing="14.0" styleClass="login-card">
      <padding>
         <Insets bottom="36.0" left="36.0" right="36.0" top="36.0" />
      </padding>

      <Label styleClass="app-title" text="Forgot password" />
      <Label styleClass="app-subtitle"
             text="Enter the email tied to your account. An administrator will review the request and issue a new 6-character password."
             wrapText="true" textAlignment="CENTER" alignment="CENTER" maxWidth="328.0" />

      <VBox spacing="4.0">
         <Label styleClass="field-label" text="Email" />
         <TextField fx:id="emailField" promptText="Enter your registered email"
                    styleClass="text-field" />
      </VBox>

      <Label fx:id="statusLabel" styleClass="status-label" text=""
             visible="false" managed="false" wrapText="true" />

      <Button fx:id="submitButton" text="Submit request" styleClass="primary-button"
              maxWidth="Infinity" onAction="#handleSubmit" />

      <Button text="Back to sign in" styleClass="secondary-button"
              maxWidth="Infinity" onAction="#goBack" />
   </VBox>

</StackPane>
