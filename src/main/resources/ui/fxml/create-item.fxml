<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="main-layout"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.ui.controller.CreateItemController">

   <!-- ===== TOP BAR ===== -->
   <top>
      <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="top-bar">
         <padding>
            <Insets bottom="12.0" left="20.0" right="20.0" top="12.0" />
         </padding>
         <Button text="← Quay lại" styleClass="back-button" onAction="#goBack" />
         <Label styleClass="app-logo" text="Tạo sản phẩm mới" />
         <Region HBox.hgrow="ALWAYS" />
      </HBox>
   </top>

   <!-- ===== CENTER: Form tạo sản phẩm ===== -->
   <center>
      <VBox alignment="TOP_CENTER" spacing="16.0">
         <padding>
            <Insets bottom="24.0" left="40.0" right="40.0" top="24.0" />
         </padding>

         <VBox maxWidth="500.0" spacing="14.0" styleClass="form-card">
            <padding>
               <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>

            <!-- Tên sản phẩm -->
            <VBox spacing="4.0">
               <Label styleClass="field-label" text="Tên sản phẩm *" />
               <TextField fx:id="nameField" promptText="Nhập tên sản phẩm"
                          styleClass="text-field" />
            </VBox>

            <!-- Mô tả -->
            <VBox spacing="4.0">
               <Label styleClass="field-label" text="Mô tả" />
               <TextArea fx:id="descriptionField" promptText="Nhập mô tả chi tiết"
                         styleClass="text-area" prefRowCount="3" wrapText="true" />
            </VBox>

            <!-- Danh mục -->
            <VBox spacing="4.0">
               <Label styleClass="field-label" text="Danh mục *" />
               <ComboBox fx:id="categoryCombo" maxWidth="Infinity" styleClass="combo-box"
                         promptText="Chọn danh mục" onAction="#handleCategoryChange">
                  <items>
                     <FXCollections fx:factory="observableArrayList">
                        <fx:value value="ELECTRONICS" />
                        <fx:value value="ART" />
                        <fx:value value="VEHICLE" />
                     </FXCollections>
                  </items>
               </ComboBox>
            </VBox>

            <!-- Chi tiết danh mục (label thay đổi theo category) -->
            <VBox spacing="4.0">
               <Label fx:id="categoryDetailLabel" styleClass="field-label"
                      text="Chi tiết danh mục *" />
               <TextField fx:id="categoryDetailField"
                          promptText="Nhập thông tin chi tiết"
                          styleClass="text-field" />
            </VBox>

            <!-- Thông báo lỗi/thành công -->
            <Label fx:id="statusLabel" styleClass="status-label" text=""
                   visible="false" wrapText="true" />

            <!-- Nút tạo -->
            <Button fx:id="createButton" text="Tạo sản phẩm" styleClass="primary-button"
                    maxWidth="Infinity" onAction="#handleCreate" />
         </VBox>
      </VBox>
   </center>

</BorderPane>
