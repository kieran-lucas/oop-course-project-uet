<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="main-layout"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.ui.controller.CreateItemController">

   <!-- ===== TOP BAR ===== -->
   <top>
      <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="top-bar">
         <padding>
            <Insets bottom="0.0" left="20.0" right="20.0" top="0.0" />
         </padding>
         <Button text="← Quay lại" styleClass="back-button" onAction="#goBack" />
         <Label styleClass="app-logo" text="Tạo sản phẩm mới" />
         <Region HBox.hgrow="ALWAYS" />
      </HBox>
   </top>

   <!-- ===== CENTER ===== -->
   <center>
      <VBox alignment="TOP_CENTER" spacing="0.0">
         <padding>
            <Insets bottom="32.0" left="40.0" right="40.0" top="28.0" />
         </padding>

         <VBox maxWidth="520.0" spacing="16.0" styleClass="form-card">
            <padding>
               <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
            </padding>

            <Label styleClass="section-title" text="Thông tin sản phẩm" />

            <VBox spacing="6.0">
               <Label styleClass="field-label" text="TÊN SẢN PHẨM *" />
               <TextField fx:id="nameField" promptText="Nhập tên sản phẩm"
                          styleClass="text-field" />
            </VBox>

            <VBox spacing="6.0">
               <Label styleClass="field-label" text="MÔ TẢ" />
               <TextArea fx:id="descriptionField" promptText="Nhập mô tả chi tiết"
                         styleClass="text-area" prefRowCount="3" wrapText="true" />
            </VBox>

            <VBox spacing="6.0">
               <Label styleClass="field-label" text="DANH MỤC *" />
               <ComboBox fx:id="categoryCombo" maxWidth="Infinity" styleClass="combo-box"
                         promptText="Chọn danh mục" onAction="#handleCategoryChange">
                  <items>
                     <FXCollections fx:factory="observableArrayList">
                        <String fx:value="ELECTRONICS" />
                        <String fx:value="ART" />
                        <String fx:value="VEHICLE" />
                     </FXCollections>
                  </items>
               </ComboBox>
            </VBox>

            <VBox spacing="6.0">
               <Label fx:id="categoryDetailLabel" styleClass="field-label"
                      text="CHI TIẾT DANH MỤC *" />
               <TextField fx:id="categoryDetailField"
                          promptText="Nhập thông tin chi tiết"
                          styleClass="text-field" />
            </VBox>

            <Label fx:id="statusLabel" styleClass="status-label" text=""
                   visible="false" managed="false" wrapText="true" />

            <Button fx:id="createButton" text="Tạo sản phẩm" styleClass="primary-button"
                    maxWidth="Infinity" onAction="#handleCreate" />
         </VBox>
      </VBox>
   </center>

</BorderPane>
