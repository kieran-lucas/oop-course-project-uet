<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="main-layout"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.ui.controller.AuctionListController">

   <!-- ===== TOP BAR ===== -->
   <top>
      <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="top-bar">
         <padding>
            <Insets bottom="0.0" left="20.0" right="20.0" top="0.0" />
         </padding>
         <Label styleClass="app-logo" text="Auction House" />
         <Region HBox.hgrow="ALWAYS" />
         <Label fx:id="usernameLabel" styleClass="username-label" text="User"
                onMouseClicked="#handleProfile">
            <graphic><Region styleClass="user-icon" /></graphic>
         </Label>
         <!-- Notification bell — only visible for BIDDER role -->
         <StackPane fx:id="bellPane" visible="false" managed="false">
            <Button fx:id="bellButton" styleClass="bell-button" onAction="#handleBellClick">
               <graphic><Region styleClass="bell-icon" /></graphic>
            </Button>
            <Label fx:id="badgeLabel" text="0" styleClass="notification-badge"
                   StackPane.alignment="TOP_RIGHT"
                   translateX="5.0" translateY="9.0"
                   visible="false" managed="false" />
         </StackPane>
         <Button styleClass="logout-button" text="Log out" onAction="#handleLogout">
            <graphic><Region styleClass="logout-icon" /></graphic>
         </Button>
      </HBox>
   </top>

   <!-- ===== CENTER ===== -->
   <center>
      <VBox spacing="16.0">
         <padding>
            <Insets bottom="24.0" left="24.0" right="24.0" top="20.0" />
         </padding>

         <!-- Toolbar: search + filter + actions -->
         <FlowPane alignment="CENTER_LEFT" hgap="10.0" vgap="10.0">
            <TextField fx:id="searchField" promptText="Search by product name..."
                       prefWidth="235.0" styleClass="search-field"
                       onAction="#handleSearch" />
            <ComboBox fx:id="statusFilter" promptText="All statuses"
                      prefWidth="135.0" styleClass="combo-box"
                      onAction="#handleSearch" />
            <ComboBox fx:id="categoryFilter" promptText="All categories"
                      prefWidth="150.0" styleClass="combo-box"
                      onAction="#handleSearch" />
            <Button text="Search" styleClass="secondary-button" onAction="#handleSearch" />
            <Button text="Refresh" styleClass="secondary-button" onAction="#handleRefresh" />
            <Button fx:id="createAuctionButton" text="+ Create Auction"
                    styleClass="primary-button" onAction="#handleCreateAuction"
                    prefWidth="180.0" minWidth="180.0"
                    visible="false" managed="false" />
         </FlowPane>

         <!--
            Auction table — column widths tuned for a 1000px min window.
            Previously some columns truncated price/status/action labels at min width.
            Slightly wider product/price/action columns + the new English headers (all
            shorter than the old Vietnamese ones) give the row enough breathing room.
         -->
         <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS" styleClass="auction-table">
            <columnResizePolicy>
               <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
               <TableColumn fx:id="itemCol"     text="Product"      prefWidth="200.0" />
               <TableColumn fx:id="categoryCol" text="Category"     prefWidth="120.0" />
               <TableColumn fx:id="priceCol"    text="Current Price" prefWidth="160.0" />
               <TableColumn fx:id="timeCol"     text="Time Left"    prefWidth="125.0" style="-fx-alignment: CENTER;" />
               <TableColumn fx:id="statusCol"   text="Status"       prefWidth="110.0" />
               <TableColumn fx:id="actionCol"   text="Actions"      prefWidth="135.0" style="-fx-alignment: CENTER;" />
            </columns>
            <placeholder>
               <Label styleClass="empty-state-label" text="No auctions available right now." />
            </placeholder>
         </TableView>

         <Label fx:id="statusLabel" styleClass="status-label" text=""
                visible="false" managed="false" />
      </VBox>
   </center>

</BorderPane>
