<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="main-layout"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.ui.controller.AuctionListController">

   <!-- ===== TOP BAR ===== -->
   <top>
      <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="top-bar">
         <padding>
            <Insets bottom="12.0" left="20.0" right="20.0" top="12.0" />
         </padding>
         <Label styleClass="app-logo" text="Auction House" />
         <Region HBox.hgrow="ALWAYS" />
         <Label fx:id="usernameLabel" styleClass="username-label" text="Người dùng" />
         <Button styleClass="logout-button" text="Đăng xuất" onAction="#handleLogout" />
      </HBox>
   </top>

   <!-- ===== CENTER — Danh sách phiên ===== -->
   <center>
      <VBox spacing="12.0">
         <padding>
            <Insets bottom="16.0" left="20.0" right="20.0" top="16.0" />
         </padding>

         <!-- Thanh tìm kiếm + filter + nút tạo phiên -->
         <HBox alignment="CENTER_LEFT" spacing="12.0">
            <TextField fx:id="searchField" promptText="Tìm kiếm theo tên sản phẩm..."
                       prefWidth="280.0" styleClass="search-field"
                       onAction="#handleSearch" />
            <ComboBox fx:id="statusFilter" promptText="Lọc theo trạng thái"
                      prefWidth="180.0" styleClass="combo-box"
                      onAction="#handleSearch" />
            <Button text="Tìm kiếm" styleClass="secondary-button" onAction="#handleSearch" />
            <Button text="Làm mới" styleClass="secondary-button" onAction="#handleRefresh" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="createAuctionButton" text="+ Tạo phiên"
                    styleClass="primary-button" onAction="#handleCreateAuction"
                    visible="false" managed="false" />
         </HBox>

         <!-- Bảng danh sách phiên đấu giá -->
         <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS" styleClass="auction-table">
            <columns>
               <TableColumn fx:id="itemCol" text="Sản phẩm" prefWidth="200.0" />
               <TableColumn fx:id="categoryCol" text="Danh mục" prefWidth="110.0" />
               <TableColumn fx:id="priceCol" text="Giá hiện tại" prefWidth="140.0" />
               <TableColumn fx:id="timeCol" text="Thời gian còn" prefWidth="140.0" />
               <TableColumn fx:id="statusCol" text="Trạng thái" prefWidth="110.0" />
               <TableColumn fx:id="actionCol" text="Hành động" prefWidth="100.0" />
            </columns>
            <placeholder>
               <Label text="Không có phiên đấu giá nào." />
            </placeholder>
         </TableView>

         <!-- Trạng thái tải dữ liệu -->
         <Label fx:id="statusLabel" styleClass="status-label" text="" />
      </VBox>
   </center>

</BorderPane>
