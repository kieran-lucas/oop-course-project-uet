<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="main-layout"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.ui.controller.AuctionListController">

   <!-- ===== TOP BAR ===== -->
   <top>
      <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="top-bar">
         <padding>
            <Insets bottom="0.0" left="20.0" right="20.0" top="0.0" />
         </padding>
         <Label styleClass="app-logo" text="Auction House" />
         <Region HBox.hgrow="ALWAYS" />
         <Label fx:id="usernameLabel" styleClass="username-label" text="Người dùng"
                onMouseClicked="#handleProfile">
            <graphic><Region styleClass="user-icon" /></graphic>
         </Label>
         <!-- Notification bell — only visible for BIDDER role -->
         <StackPane fx:id="bellPane" visible="false" managed="false">
            <Button fx:id="bellButton" styleClass="bell-button" onAction="#handleBellClick">
               <graphic><Region styleClass="bell-icon" /></graphic>
            </Button>
            <Label fx:id="badgeLabel" text="0" styleClass="notification-badge"
                   StackPane.alignment="TOP_RIGHT"
                   translateX="5.0" translateY="9.0"
                   visible="false" managed="false" />
         </StackPane>
         <Button styleClass="logout-button" text="Đăng xuất" onAction="#handleLogout"
                 style="-fx-font-family: 'Lexend'; -fx-font-weight: bold; -fx-font-size: 14px;">
            <graphic><Region styleClass="logout-icon" /></graphic>
         </Button>
      </HBox>
   </top>

   <!-- ===== CENTER ===== -->
   <center>
      <VBox spacing="16.0">
         <padding>
            <Insets bottom="24.0" left="24.0" right="24.0" top="20.0" />
         </padding>

         <!-- Toolbar: search + filter + actions -->
         <HBox alignment="CENTER_LEFT" spacing="10.0">
            <TextField fx:id="searchField" promptText="Tìm theo tên sản phẩm..."
                       prefWidth="200.0" styleClass="search-field"
                       onAction="#handleSearch" />
            <ComboBox fx:id="statusFilter" promptText="Lọc trạng thái"
                      prefWidth="150.0" styleClass="combo-box"
                      onAction="#handleSearch" />
            <ComboBox fx:id="categoryFilter" promptText="Lọc danh mục"
                      prefWidth="150.0" styleClass="combo-box"
                      onAction="#handleSearch" />
            <Button text="Tìm" styleClass="secondary-button" onAction="#handleSearch" />
            <Button text="Làm mới" styleClass="secondary-button" onAction="#handleRefresh" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="createAuctionButton" text="+ Tạo phiên đấu giá"
                    styleClass="primary-button" onAction="#handleCreateAuction"
                    visible="false" managed="false" />
         </HBox>

         <!-- Auction table -->
         <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS" styleClass="auction-table">
            <columnResizePolicy>
               <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
               <TableColumn fx:id="itemCol"     text="Sản phẩm"      prefWidth="220.0" />
               <TableColumn fx:id="categoryCol" text="Danh mục"      prefWidth="110.0" />
               <TableColumn fx:id="priceCol"    text="Giá hiện tại"  prefWidth="150.0" />
               <TableColumn fx:id="timeCol"     text="Thời gian còn" prefWidth="140.0" />
               <TableColumn fx:id="statusCol"   text="Trạng thái"    prefWidth="110.0" />
               <TableColumn fx:id="actionCol"   text="Hành động"     prefWidth="100.0" />
            </columns>
            <placeholder>
               <Label text="Không có phiên đấu giá nào." />
            </placeholder>
         </TableView>

         <Label fx:id="statusLabel" styleClass="status-label" text=""
                visible="false" managed="false" />
      </VBox>
   </center>

</BorderPane>