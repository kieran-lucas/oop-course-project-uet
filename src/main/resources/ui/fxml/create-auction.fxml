<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="main-layout"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.ui.controller.CreateAuctionController">

   <!-- ===== TOP BAR ===== -->
   <top>
      <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="top-bar">
         <padding>
            <Insets bottom="0.0" left="20.0" right="20.0" top="0.0" />
         </padding>
         <Button text="Back" styleClass="back-button" onAction="#goBack">
            <graphic><Region styleClass="back-icon" /></graphic>
         </Button>
         <Label styleClass="app-logo" text="Create Auction" />
         <Region HBox.hgrow="ALWAYS" />
      </HBox>
   </top>

   <!-- ===== CENTER ===== -->
   <center>
      <VBox alignment="TOP_CENTER" spacing="0.0">
         <padding>
            <Insets bottom="32.0" left="40.0" right="40.0" top="28.0" />
         </padding>

         <VBox maxWidth="540.0" spacing="16.0" styleClass="form-card">
            <padding>
               <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
            </padding>

            <Label styleClass="section-title" text="Auction details" />

            <VBox spacing="6.0">
               <Label styleClass="field-label" text="PRODUCT *" />
               <ComboBox fx:id="itemCombo" maxWidth="Infinity" styleClass="combo-box"
                         promptText="Choose one of your products" />
               <HBox spacing="8.0">
                  <Button fx:id="editItemButton" text="Edit selected product"
                          styleClass="link-button" disable="true" onAction="#handleEditItem" />
                  <Button fx:id="deleteItemButton" text="Delete selected product"
                          styleClass="link-button" disable="true" onAction="#handleDeleteItem" />
               </HBox>
               <Button text="+ Create a new product" styleClass="link-button"
                       onAction="#goToCreateItem" />
            </VBox>

            <VBox spacing="6.0">
               <Label styleClass="field-label" text="STARTING PRICE (VND) *" />
               <TextField fx:id="startingPriceField" promptText="Enter starting price"
                          styleClass="text-field" />
            </VBox>

            <!-- Start date + time on one row -->
            <VBox spacing="6.0">
               <Label styleClass="field-label" text="START DATE &amp; TIME *" />
               <HBox spacing="10.0">
                  <DatePicker fx:id="startDatePicker" styleClass="date-picker auction-calendar-glass-picker"
                              promptText="dd/mm/yyyy" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
                  <TextField fx:id="startTimeField" promptText="HH:mm"
                             styleClass="text-field" prefWidth="110.0" />
               </HBox>
            </VBox>

            <!-- End date + time on one row -->
            <VBox spacing="6.0">
               <Label styleClass="field-label" text="END DATE &amp; TIME *" />
               <HBox spacing="10.0">
                  <DatePicker fx:id="endDatePicker" styleClass="date-picker auction-calendar-glass-picker"
                              promptText="dd/mm/yyyy" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
                  <TextField fx:id="endTimeField" promptText="HH:mm"
                             styleClass="text-field" prefWidth="110.0" />
               </HBox>
            </VBox>

            <Label fx:id="statusLabel" styleClass="status-label" text=""
                   visible="false" managed="false" wrapText="true" />

            <Button fx:id="createButton" text="Create auction" styleClass="primary-button"
                    maxWidth="Infinity" onAction="#handleCreate" />
         </VBox>
      </VBox>
   </center>

</BorderPane>
