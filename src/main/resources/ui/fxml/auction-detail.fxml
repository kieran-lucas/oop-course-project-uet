<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.AreaChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="main-layout"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.ui.controller.AuctionDetailController">

   <!-- ===== TOP BAR ===== -->
   <top>
      <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="top-bar">
         <padding>
            <Insets bottom="0.0" left="20.0" right="20.0" top="0.0" />
         </padding>
         <Button text="← Quay lại" styleClass="back-button" onAction="#goBack" />
         <Label styleClass="app-logo" text="Auction House" />
         <Region HBox.hgrow="ALWAYS" />
         <Label fx:id="usernameLabel" styleClass="username-label" text=""
                onMouseClicked="#handleProfile" />
      </HBox>
   </top>

   <!-- ===== CENTER ===== -->
   <center>
      <VBox>
      <!-- Notification toast — hiển thị tạm 3 giây khi có bid mới -->
      <Label fx:id="bidNotificationLabel"
             text=""
             visible="false" managed="false"
             alignment="CENTER"
             maxWidth="Infinity"
             style="-fx-background-color: #1565c0; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 10 20 10 20; -fx-font-weight: bold;" />
      <HBox fx:id="contentHBox" spacing="20.0" VBox.vgrow="ALWAYS">
         <padding>
            <Insets bottom="24.0" left="24.0" right="24.0" top="22.0" />
         </padding>

         <!-- ===== LEFT COLUMN (scrollable) ===== -->
         <ScrollPane fx:id="leftScrollPane" fitToWidth="true"
                     HBox.hgrow="NEVER" minWidth="0"
                     vbarPolicy="AS_NEEDED" hbarPolicy="NEVER"
                     styleClass="page-scroll">
         <VBox fx:id="leftColumn" spacing="14.0">

            <!-- Item header -->
            <VBox spacing="6.0" styleClass="info-card">
               <padding><Insets bottom="18.0" left="20.0" right="20.0" top="18.0" /></padding>
               <HBox alignment="CENTER_LEFT" spacing="12.0">
                  <Label fx:id="itemNameLabel" styleClass="detail-title" text="Đang tải..."
                         HBox.hgrow="ALWAYS" />
                  <Label fx:id="auctionStatusLabel" styleClass="status-badge" text="" />
               </HBox>
               <Label fx:id="itemCategoryLabel" styleClass="detail-subtitle" text="" />
               <Label fx:id="itemDescriptionLabel" styleClass="detail-text" text=""
                      wrapText="true" />
            </VBox>

            <!-- Stat strip: Price | Leader | Time -->
            <HBox spacing="10.0">
               <VBox alignment="CENTER_LEFT" spacing="6.0" styleClass="stat-card-price"
                     HBox.hgrow="ALWAYS">
                  <Label styleClass="stat-label" text="GIÁ HIỆN TẠI" />
                  <Label fx:id="currentPriceLabel" styleClass="price-highlight" text="—" />
               </VBox>
               <VBox alignment="CENTER_LEFT" spacing="6.0" styleClass="stat-card"
                     HBox.hgrow="SOMETIMES" prefWidth="160.0">
                  <Label styleClass="stat-label" text="NGƯỜI DẪN ĐẦU" />
                  <Label fx:id="leadingBidderLabel" styleClass="detail-text" text="—" />
               </VBox>
               <VBox alignment="CENTER_LEFT" spacing="6.0" styleClass="stat-card-timer"
                     HBox.hgrow="NEVER" prefWidth="140.0">
                  <Label styleClass="stat-label" text="THỜI GIAN CÒN" />
                  <Label fx:id="countdownLabel" styleClass="countdown-label" text="—" />
               </VBox>
            </HBox>

            <!-- Bid actions (hidden when not BIDDER / session ended) -->
            <VBox fx:id="bidBox" spacing="14.0" styleClass="info-card">
               <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>

               <!-- Manual bid -->
               <HBox alignment="CENTER_LEFT" spacing="0.0">
                  <Label styleClass="section-title" text="Đặt giá thủ công" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="balanceLabel" text="Số dư: —"
                         style="-fx-font-size: 11px; -fx-text-fill: #90a4ae;" />
               </HBox>
               <HBox spacing="10.0" alignment="CENTER_LEFT">
                  <TextField fx:id="bidAmountField" promptText="Nhập số tiền (VND)"
                             styleClass="text-field" HBox.hgrow="ALWAYS" />
                  <Button fx:id="bidButton" text="Đặt giá" styleClass="primary-button"
                          onAction="#handleBid" />
               </HBox>
               <Label fx:id="bidErrorLabel" styleClass="error-label" text=""
                      visible="false" managed="false" wrapText="true" />

               <Separator />

               <!-- Auto-bid -->
               <Label styleClass="section-title" text="Auto-bid tự động" />
               <HBox spacing="12.0">
                  <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                     <Label styleClass="field-label" text="GIÁ TỐI ĐA (VND)" />
                     <TextField fx:id="maxBidField" promptText="VD: 10,000,000"
                                styleClass="text-field" />
                  </VBox>
                  <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                     <Label styleClass="field-label" text="BƯỚC TĂNG (VND)" />
                     <TextField fx:id="incrementField" promptText="VD: 100,000"
                                styleClass="text-field" />
                  </VBox>
               </HBox>
               <HBox spacing="10.0">
                  <Button fx:id="autoBidButton" text="Bật auto-bid" styleClass="primary-button"
                          onAction="#handleAutoBid" />
                  <Button fx:id="cancelAutoBidButton" text="Tắt auto-bid"
                          styleClass="secondary-button" onAction="#handleCancelAutoBid" />
               </HBox>
               <Label fx:id="autoBidStatusLabel" styleClass="detail-text" text=""
                      wrapText="true" />
            </VBox>

            <!-- Session ended notice -->
            <VBox fx:id="endedBox" spacing="8.0" styleClass="info-card"
                  visible="false" managed="false">
               <padding><Insets bottom="18.0" left="20.0" right="20.0" top="18.0" /></padding>
               <Label styleClass="section-title" text="Phiên đã kết thúc" />
               <Label fx:id="winnerLabel" styleClass="winner-label" text="" />
            </VBox>
         </VBox>
         </ScrollPane>

         <!-- ===== RIGHT COLUMN ===== -->
         <VBox fx:id="rightColumn" spacing="14.0" HBox.hgrow="NEVER" minWidth="0">

            <!-- Chart in card -->
            <VBox spacing="10.0" styleClass="info-card">
               <padding><Insets bottom="18.0" left="18.0" right="18.0" top="18.0" /></padding>
               <Label styleClass="section-title" text="Biểu đồ giá thầu" />
               <AreaChart fx:id="bidChart" prefHeight="320.0" animated="false">
                  <xAxis>
                     <NumberAxis label="Lần đặt" />
                  </xAxis>
                  <yAxis>
                     <NumberAxis label="Giá (VND)" />
                  </yAxis>
               </AreaChart>
            </VBox>

            <!-- Bid history -->
            <Label styleClass="section-title" text="Lịch sử đặt giá" />
            <ListView fx:id="bidHistoryList" VBox.vgrow="ALWAYS"
                      styleClass="bid-history-list" />
         </VBox>
      </HBox>
      </VBox>
   </center>

</BorderPane>
