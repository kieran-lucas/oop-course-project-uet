<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.AreaChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="main-layout"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.ui.controller.AuctionDetailController">

   <!-- ===== TOP BAR ===== -->
   <top>
      <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="top-bar">
         <padding>
            <Insets bottom="0.0" left="20.0" right="20.0" top="0.0" />
         </padding>
         <Button text="Back" styleClass="back-button" onAction="#goBack">
            <graphic><Region styleClass="back-icon" /></graphic>
         </Button>
         <Label styleClass="app-logo" text="Auction House" />
         <Region HBox.hgrow="ALWAYS" />
         <Label fx:id="usernameLabel" styleClass="username-label" text=""
                onMouseClicked="#handleProfile">
            <graphic><Region styleClass="user-icon" /></graphic>
         </Label>
      </HBox>
   </top>

   <!-- ===== CENTER ===== -->
   <center>
      <VBox>
      <!-- Notification toast — appears briefly when a new bid arrives. Styled via
           .bid-toast in CSS so semantic variants (.success/.warn/.error) can be applied
           by the controller through styleClass without inline-style churn. -->
      <Label fx:id="bidNotificationLabel"
             text=""
             visible="false" managed="false"
             alignment="CENTER"
             maxWidth="Infinity"
             styleClass="bid-toast" />
      <HBox fx:id="contentHBox" spacing="20.0" VBox.vgrow="ALWAYS">
         <padding>
            <Insets bottom="24.0" left="24.0" right="24.0" top="22.0" />
         </padding>

         <!-- ===== LEFT COLUMN (scrollable) ===== -->
         <ScrollPane fx:id="leftScrollPane" fitToWidth="true"
                     HBox.hgrow="NEVER" minWidth="0"
                     vbarPolicy="AS_NEEDED" hbarPolicy="NEVER"
                     styleClass="page-scroll">
         <VBox fx:id="leftColumn" spacing="14.0">

            <!-- Item header -->
            <VBox spacing="6.0" styleClass="info-card">
               <padding><Insets bottom="18.0" left="20.0" right="20.0" top="18.0" /></padding>
               <HBox alignment="CENTER_LEFT" spacing="12.0">
                  <Label fx:id="itemNameLabel" styleClass="detail-title" text="Loading..."
                         HBox.hgrow="ALWAYS" />
                  <Label fx:id="auctionStatusLabel" styleClass="status-badge" text="" />
               </HBox>
               <Label fx:id="itemCategoryLabel" styleClass="detail-subtitle" text="" />
               <!-- Category-specific metadata: only one of the three labels is shown at a time -->
               <Label fx:id="itemBrandLabel" styleClass="detail-subtitle" text=""
                      visible="false" managed="false" />
               <Label fx:id="itemArtistLabel" styleClass="detail-subtitle" text=""
                      visible="false" managed="false" />
               <Label fx:id="itemYearLabel" styleClass="detail-subtitle" text=""
                      visible="false" managed="false" />
               <Label fx:id="startingPriceLabel" styleClass="detail-subtitle" text=""
                      visible="false" managed="false" />
               <Label fx:id="itemDescriptionLabel" styleClass="detail-text" text=""
                      wrapText="true" />
            </VBox>

            <!-- Stat strip: Price | Leader | Time -->
            <HBox spacing="10.0">
               <VBox alignment="CENTER_LEFT" spacing="6.0" styleClass="stat-card-price"
                     HBox.hgrow="ALWAYS">
                  <Label styleClass="stat-label" text="CURRENT PRICE" />
                  <Label fx:id="currentPriceLabel" styleClass="price-highlight" text="—" />
               </VBox>
               <VBox alignment="CENTER_LEFT" spacing="6.0" styleClass="stat-card"
                     HBox.hgrow="SOMETIMES" prefWidth="170.0">
                  <Label styleClass="stat-label" text="LEADING BIDDER" />
                  <Label fx:id="leadingBidderLabel" styleClass="detail-text" text="—" />
               </VBox>
               <VBox alignment="CENTER_LEFT" spacing="6.0" styleClass="stat-card-timer"
                     HBox.hgrow="NEVER" prefWidth="150.0">
                  <Label fx:id="timerHeaderLabel" styleClass="stat-label" text="TIME LEFT" />
                  <Label fx:id="countdownLabel" styleClass="countdown-label" text="—" />
               </VBox>
            </HBox>

            <!-- Bid actions (hidden when not BIDDER / session ended) -->
            <VBox fx:id="bidBox" spacing="14.0" styleClass="info-card">
               <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>

               <!-- Manual bid -->
               <HBox alignment="CENTER_LEFT" spacing="0.0">
                  <Label styleClass="section-title" text="Place a bid" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="balanceLabel" text="Balance: —" styleClass="balance-inline" />
               </HBox>
               <HBox spacing="10.0" alignment="CENTER_LEFT">
                  <TextField fx:id="bidAmountField" promptText="Enter amount (VND)"
                             styleClass="text-field" HBox.hgrow="ALWAYS" />
                  <Button fx:id="bidButton" text="Bid" styleClass="primary-button"
                          onAction="#handleBid" />
               </HBox>
               <Label fx:id="bidErrorLabel" styleClass="error-label" text=""
                      visible="false" managed="false" wrapText="true" />

               <Separator />

               <!-- Auto-bid — styled via .glass-subsurface so it visually nests inside the
                    bid card instead of competing with it. -->
               <Label styleClass="section-title" text="Auto-bid" />
               <VBox spacing="12.0" styleClass="glass-subsurface">
                  <padding><Insets bottom="14.0" left="14.0" right="14.0" top="14.0" /></padding>
                  <HBox spacing="12.0">
                     <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="field-label" text="MAX BID (VND)" />
                        <TextField fx:id="maxBidField" promptText="e.g. 10,000,000"
                                   styleClass="text-field" />
                     </VBox>
                     <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="field-label" text="INCREMENT (VND)" />
                        <TextField fx:id="incrementField" promptText="e.g. 100,000"
                                   styleClass="text-field" />
                     </VBox>
                  </HBox>
                  <HBox spacing="12.0" alignment="CENTER_LEFT">
                     <Button fx:id="autoBidButton" text="Turn on auto-bid" styleClass="primary-button"
                             onAction="#handleAutoBid" />
                     <Button fx:id="cancelAutoBidButton" text="Turn off"
                             styleClass="secondary-button" onAction="#handleCancelAutoBid" />
                     <Label fx:id="autoBidSpinner" text="⚙"
                            visible="false" managed="false"
                            styleClass="autobid-counter" />
                  </HBox>
                  <Label fx:id="autoBidStatusLabel" styleClass="detail-text" text=""
                         wrapText="true" />
               </VBox>
            </VBox>

            <!-- Session ended notice -->
            <VBox fx:id="endedBox" spacing="8.0" styleClass="info-card"
                  visible="false" managed="false">
               <padding><Insets bottom="18.0" left="20.0" right="20.0" top="18.0" /></padding>
               <Label styleClass="section-title" text="Auction has ended" />
               <Label fx:id="winnerLabel" styleClass="winner-label" text="" />
            </VBox>
         </VBox>
         </ScrollPane>

         <!-- ===== RIGHT COLUMN ===== -->
         <VBox fx:id="rightColumn" spacing="14.0" HBox.hgrow="NEVER" minWidth="0">

            <!-- Chart in card -->
            <VBox spacing="10.0" styleClass="info-card">
               <padding><Insets bottom="18.0" left="18.0" right="18.0" top="18.0" /></padding>
               <Label styleClass="section-title" text="Price history" />
               <AreaChart fx:id="bidChart" prefHeight="320.0" animated="false">
                  <xAxis>
                     <NumberAxis label="Bid #" />
                  </xAxis>
                  <yAxis>
                     <NumberAxis label="Price (VND)" />
                  </yAxis>
               </AreaChart>
            </VBox>

            <!-- Bid history -->
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <Label styleClass="section-title" text="Bid history" />
               <Region HBox.hgrow="ALWAYS" />
               <Label fx:id="totalBidsLabel" text="0 bids" styleClass="muted-caption" />
            </HBox>
            <ListView fx:id="bidHistoryList" VBox.vgrow="ALWAYS"
                      styleClass="bid-history-list" />
         </VBox>
      </HBox>
      </VBox>
   </center>

</BorderPane>
