<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="login-root"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.auction.ui.controller.RegisterController">

   <VBox alignment="CENTER" maxWidth="480.0" spacing="14.0" styleClass="login-card">
      <padding>
         <Insets bottom="40.0" left="44.0" right="44.0" top="36.0" />
      </padding>

      <Label styleClass="app-title" text="Online Auction" />
      <Label styleClass="app-subtitle" text="Create a new account" />

      <VBox spacing="6.0">
         <Label styleClass="field-label" text="USERNAME" />
         <TextField fx:id="usernameField" promptText="Enter your username"
                    styleClass="text-field" />
      </VBox>

      <VBox spacing="6.0">
         <Label styleClass="field-label" text="EMAIL" />
         <TextField fx:id="emailField" promptText="Enter your email address"
                    styleClass="text-field" />
      </VBox>

      <VBox spacing="6.0">
         <Label styleClass="field-label" text="PASSWORD" />
         <PasswordField fx:id="passwordField" promptText="At least 6 characters"
                        styleClass="text-field, password-field" />
      </VBox>

      <VBox spacing="6.0">
         <Label styleClass="field-label" text="CONFIRM PASSWORD" />
         <PasswordField fx:id="confirmPasswordField" promptText="Re-enter your password"
                        styleClass="text-field, password-field" />
      </VBox>

      <VBox spacing="6.0">
         <Label styleClass="field-label" text="ROLE" />
         <ComboBox fx:id="roleCombo" maxWidth="Infinity" styleClass="combo-box"
                   promptText="Choose a role">
            <items>
               <FXCollections fx:factory="observableArrayList">
                  <String fx:value="BIDDER" />
                  <String fx:value="SELLER" />
               </FXCollections>
            </items>
         </ComboBox>
      </VBox>

      <Label fx:id="errorLabel" styleClass="error-label" text=""
             visible="false" managed="false" wrapText="true" />

      <Button fx:id="registerButton" styleClass="primary-button" text="Create account"
              maxWidth="Infinity" onAction="#handleRegister" />

      <HBox alignment="CENTER">
         <Hyperlink text="Already have an account? Sign in" onAction="#goToLogin"
                    styleClass="link" />
      </HBox>
   </VBox>

</StackPane>
