<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="login-root"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.auction.ui.controller.RegisterController">

   <VBox alignment="CENTER" maxWidth="480.0" spacing="14.0" styleClass="login-card">
      <padding>
         <Insets bottom="40.0" left="44.0" right="44.0" top="36.0" />
      </padding>

      <Label styleClass="app-title" text="Online Auction" />
      <Label styleClass="app-subtitle" text="Tạo tài khoản mới" />

      <VBox spacing="6.0">
         <Label styleClass="field-label" text="TÊN ĐĂNG NHẬP" />
         <TextField fx:id="usernameField" promptText="Nhập tên đăng nhập"
                    styleClass="text-field" />
      </VBox>

      <VBox spacing="6.0">
         <Label styleClass="field-label" text="EMAIL" />
         <TextField fx:id="emailField" promptText="Nhập địa chỉ email"
                    styleClass="text-field" />
      </VBox>

      <VBox spacing="6.0">
         <Label styleClass="field-label" text="MẬT KHẨU" />
         <PasswordField fx:id="passwordField" promptText="Ít nhất 6 ký tự"
                        styleClass="text-field" />
      </VBox>

      <VBox spacing="6.0">
         <Label styleClass="field-label" text="XÁC NHẬN MẬT KHẨU" />
         <PasswordField fx:id="confirmPasswordField" promptText="Nhập lại mật khẩu"
                        styleClass="text-field" />
      </VBox>

      <VBox spacing="6.0">
         <Label styleClass="field-label" text="VAI TRÒ" />
         <ComboBox fx:id="roleCombo" maxWidth="Infinity" styleClass="combo-box"
                   promptText="Chọn vai trò">
            <items>
               <FXCollections fx:factory="observableArrayList">
                  <String fx:value="BIDDER" />
                  <String fx:value="SELLER" />
               </FXCollections>
            </items>
         </ComboBox>
      </VBox>

      <Label fx:id="errorLabel" styleClass="error-label" text=""
             visible="false" managed="false" wrapText="true" />

      <Button fx:id="registerButton" styleClass="primary-button" text="Đăng ký"
              maxWidth="Infinity" onAction="#handleRegister" />

      <HBox alignment="CENTER">
         <Hyperlink text="Đã có tài khoản? Đăng nhập" onAction="#goToLogin"
                    styleClass="link" />
      </HBox>
   </VBox>

</StackPane>
